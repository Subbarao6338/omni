<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing Outer Accent Ring -->
    <path
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,12 A42,42 0 1,0 54,96 A42,42 0 1,0 54,12 Z">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="12"
                android:startY="12"
                android:endX="96"
                android:endY="96"
                android:type="linear">
                <item android:color="#40FFE082" android:offset="0.0" />
                <item android:color="#00FFB300" android:offset="0.5" />
                <item android:color="#40FFB300" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Golden Gradient Definition for Outer Shield -->
    <path
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,20 L80,30 L80,55 C80,72 69,84 54,88 C39,84 28,72 28,55 L28,30 Z">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="28"
                android:startY="20"
                android:endX="80"
                android:endY="88"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFD54F" android:offset="0.3" />
                <item android:color="#FFB300" android:offset="0.7" />
                <item android:color="#FF8F00" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Golden Gradient Definition for Inner Nested Shield (Sleek Double Border) -->
    <path
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,26 L74,34 L74,53 C74,67 65,77 54,81 C43,77 34,67 34,53 L34,34 Z">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="34"
                android:startY="26"
                android:endX="74"
                android:endY="81"
                android:type="linear">
                <item android:color="#FFF9C4" android:offset="0.0" />
                <item android:color="#FFE082" android:offset="0.4" />
                <item android:color="#FFB300" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Golden Gradient Definition for Inner Globe -->
    <path
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,32 A18,18 0 1,0 54,68 A18,18 0 1,0 54,32 Z">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="36"
                android:startY="32"
                android:endX="72"
                android:endY="68"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFB300" android:offset="0.7" />
                <item android:color="#FF6F00" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Globe Horizontal Grid Line -->
    <path
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M36,50 L72,50">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="36"
                android:startY="50"
                android:endX="72"
                android:endY="50"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFB300" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Globe Vertical Grid Line -->
    <path
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M54,32 L54,68">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="54"
                android:startY="32"
                android:endX="54"
                android:endY="68"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFB300" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Left longitude curve -->
    <path
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M40,41 C44,45 44,55 40,59">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="40"
                android:startY="41"
                android:endX="40"
                android:endY="59"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFB300" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right longitude curve -->
    <path
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M68,41 C64,45 64,55 68,59">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="68"
                android:startY="41"
                android:endX="68"
                android:endY="59"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFB300" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Tech Corner Details (Top-Left) -->
    <path
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M18,30 L18,18 L30,18">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="18"
                android:startY="18"
                android:endX="30"
                android:endY="30"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFB300" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Tech Corner Details (Bottom-Right) -->
    <path
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M90,78 L90,90 L78,90">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="78"
                android:startY="78"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:color="#FFB300" android:offset="0.0" />
                <item android:color="#FF8F00" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
